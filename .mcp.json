{
  "mcpServers": {
    "mixdog": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/server.mjs"],
      "cwd": "${CLAUDE_PLUGIN_ROOT}",
      "env": {
        "CLAUDE_PLUGIN_ROOT": "${CLAUDE_PLUGIN_ROOT}",
        "CLAUDE_PLUGIN_DATA": "${CLAUDE_PLUGIN_DATA}"
      },
      "timeout": 120000
    }
  }
}
